[core]
    editor = vim
[init]
    defaultBranch = main
[color]
    ui = auto
[merge]
    tool = vimdiff
[format]
    pretty = format:%C(bold red)%h%C(reset) %C(bold cyan)%ar%C(reset) %C(magenta)%d%C(reset) %s %C(reset)
[alias]
    a = add
    aa = add --all
    ca = commit --amend
    ci = commit --verbose
    cia = commit --amend --verbose
    co = checkout
    di = diff
    dic = diff --cached
    di1 = diff HEAD~
    st = status
    ff = merge --ff-only
    pff = pull --ff-only
    noff = merge --no-ff
    fa = fetch --all
    p = push
    po = push origin
    pom = push origin master
    poma = push origin main
    poml = push origin mainline
    pod = push origin dev

    l = "!. ~/userconf/shell_config/70_githelpers.sh && pretty_git_log"
    r = !GIT_NO_PAGER=1 git l -30
    ra = !git r --all
    head = !git r -1
    h = !git head
    b = "!. ~/userconf/shell_config/70_githelpers.sh && pretty_git_branch_sorted"

# Identity is a fact about a machine (sometimes about a tree), not about this
# repo, so it is not tracked here. deploy.sh creates ~/.gitconfig_local if it is
# missing and never touches it again. Last word wins in git config, so this
# include sits at the bottom: anything in the local file overrides the base
# above it, and per-tree identity is one [includeIf "gitdir:..."] section in
# that same local file. A missing include path is silently ignored by git.
[include]
    path = ~/.gitconfig_local

